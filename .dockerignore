# .dockerignore — keep the runner build context slim and stateless (M5 §3.1 D-O).
# The builder stage does `COPY . /src`; only pyproject.toml + uv.lock + README.md +
# cv_infra/ are actually needed for the wheel build. Everything volatile, secret or
# team-external stays OUT of the context (never baked into any layer; LOCKED §15).

# --- VCS / local env / secrets ---
.git
.gitignore
.env
.venv

# --- Tool caches / build residue ---
__pycache__
**/__pycache__
**/*.py[cod]
.ruff_cache
.pytest_cache
.mypy_cache
.import_linter_cache
dist
build
*.egg-info

# --- Verification outputs & recordings (mounted at runtime, never baked) ---
results
out
*.mcap
*.mp4
*.log

# --- Repo areas not part of the wheel (context slimming) ---
docker
scripts
tests
.github
docs
profiles
