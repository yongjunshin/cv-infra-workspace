; import-linter configuration (M8 / DoD-P0-04) — boundary enforcement.
;
; Phase 0 layer rule: ``cv_infra.contract`` is the foundational (lowest) layer.
; Every other sub-package may depend on the contract, but the contract must NOT
; depend on any of them. Encoded as a ``forbidden`` contract so siblings stay
; free to evolve their own dependency order (only the contract-is-lowest
; boundary is enforced — the precise rule the gate requires, nothing more).
;
; This file is the seed for the cross-repo boundary enforcement that grows in
; later Phases (consumer must not import platform sources, etc.).

[importlinter]
root_package = cv_infra

[importlinter:contract:contract-is-foundational]
name = cv_infra.contract is the foundational layer (imports no sibling package)
type = forbidden
source_modules =
    cv_infra.contract
forbidden_modules =
    cv_infra.orchestrator
    cv_infra.runner
    cv_infra.report
    cv_infra.cli
    cv_infra.oracles
    cv_infra.adapter
; P3 cycle-1 (M1 §3.3 stage 5): the contract loader BINDS oracle plugins via the
; M1-owned loader entry in cv_infra/oracles/base.py (itself stdlib+contract.errors
; only). This single sanctioned edge is allowed; everything else in
; cv_infra.oracles (concrete M2 oracles) stays forbidden to the contract.
ignore_imports =
    cv_infra.contract.loader -> cv_infra.oracles.base
