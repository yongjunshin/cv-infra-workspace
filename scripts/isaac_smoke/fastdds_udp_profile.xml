<?xml version="1.0" encoding="UTF-8"?>
<!--
fastdds_udp_profile.xml — force Fast DDS onto UDPv4-only transport (R8, LOCKED).

Why: Fast DDS default builtin transports include shared memory (SHM). Across separate
docker containers /dev/shm and the IPC namespace are NOT shared, so SHM can silently
break runner<->SUT communication. This profile disables builtin transports entirely and
registers a single UDPv4 transport (DoD-P1-05: "SHM->UDP transport 강제 확인").

Discovery: multicast discovery over the dedicated docker bridge network is MEASURED by
run_dds_handshake.sh first (R8 measure-and-adjust). If multicast fails, the wrapper
generates a variant of this file with an <initialPeersList> unicast entry per side and
records that fallback — see scripts/isaac_smoke/README.md.

Loaded on BOTH sides via FASTRTPS_DEFAULT_PROFILES_FILE (Isaac internal Jazzy bridge and
the ros:jazzy peer are both Fast DDS 2.14.x / rmw_fastrtps_cpp).
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>cv_udp_transport</transport_id>
            <type>UDPv4</type>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="cv_infra_udp_only" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>cv_udp_transport</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
        </rtps>
    </participant>
</profiles>
